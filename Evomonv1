if not game:IsLoaded() then game.Loaded:Wait() end

-- Reset global state
getgenv().catchEnabled          = false
getgenv().catchMode             = "catch"
getgenv().autoCatchOnHit        = false
getgenv().catchBall             = "normal"
getgenv().autoQuestEnabled      = false
getgenv().mobDeadCheck          = false
getgenv().antiAfkEnabled        = true
getgenv()._bossCaptureDone      = false
getgenv()._capturedArgs         = nil
getgenv()._isListening          = false
getgenv()._setupLocked          = false
getgenv()._isListeningRoll      = false
getgenv()._rollCaptureDone      = false
getgenv()._capturedRollArgs     = nil
getgenv()._isListeningBoss5m    = false
getgenv()._boss5mUUID           = nil
getgenv()._boss5mCaptureDone    = false
getgenv().__EvomSpeedActive     = false

-- Load Rayfield
local ok, Rayfield = pcall(function()
    return loadstring(game:HttpGet("https://sirius.menu/rayfield"))()
end)

if not ok or not Rayfield or type(Rayfield.CreateWindow) ~= "function" then
    warn("[EvomonRoblox Loader] Failed to load Rayfield.")
    return
end

getgenv().__EvomRayfield = Rayfield

local _premiumVerified = false

local ReplicatedStorage        = game:GetService("ReplicatedStorage")
local ReqEnterNpcBattle        = ReplicatedStorage:WaitForChild("Remote"):WaitForChild("Battle"):WaitForChild("ReqEnterNpcBattle")
local ReqDrawProfession        = ReplicatedStorage:WaitForChild("Remote"):WaitForChild("Profession"):WaitForChild("ReqDrawProfession")
local ReqReportEnterBossBattle = ReplicatedStorage:WaitForChild("Remote"):WaitForChild("Battle"):WaitForChild("ReqReportEnterBossBattle")

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args   = table.pack(...)

    -- Boss capture
    if getgenv()._isListening and self == ReqEnterNpcBattle and method == "FireServer" then
        getgenv()._capturedArgs    = args
        getgenv()._isListening     = false
        getgenv()._setupLocked     = false
        getgenv()._bossCaptureDone = true
        return oldNamecall(self, table.unpack(args, 1, args.n))
    end

    -- Boss 5m capture
    if getgenv()._isListeningBoss5m and self == ReqReportEnterBossBattle and method == "FireServer" then
        getgenv()._boss5mUUID        = args[2]
        getgenv()._isListeningBoss5m = false
        getgenv()._boss5mCaptureDone = true
        return oldNamecall(self, table.unpack(args, 1, args.n))
    end

    -- Roll capture
    if getgenv()._isListeningRoll and self == ReqDrawProfession and method == "InvokeServer" then
        getgenv()._capturedRollArgs = args
        getgenv()._isListeningRoll  = false
        getgenv()._rollCaptureDone  = true
        return oldNamecall(self, table.unpack(args, 1, args.n))
    end

    if getgenv().__EvomSpeedIntercept then
        local result = getgenv().__EvomSpeedIntercept(self, method, args, oldNamecall)
        if result ~= nil then return result end
    end

    return oldNamecall(self, table.unpack(args, 1, args.n))
end)

-- Auth handshake token
local _authToken = tostring(math.random(2^20, 2^30)) .. tostring(math.floor(tick() * 1000))

getgenv().__EvomSetAuth = function(isPrem, isPremPlus, token)
    if token ~= _authToken then return end
    getgenv().__EvomSetAuth     = nil
    getgenv().__EvomLoaderToken = nil
    _premiumVerified              = isPrem == true
    getgenv().__EvomIsPremium     = function() return _premiumVerified end
    getgenv().__EvomIsPremiumPlus = function() return isPremPlus == true end
    getgenv().__EvomAuthed        = true
end

getgenv().__EvomLoaderToken = _authToken
getgenv().__EvomLoaderReady = true

