if not game:IsLoaded() then game.Loaded:Wait() end

-- Reset global state
getgenv().catchMob         = false
getgenv().mobDeadCheck     = false
getgenv().battleModeSet    = false
getgenv().antiAfkEnabled   = true
getgenv()._bossCaptureDone = false
getgenv()._capturedArgs    = nil
getgenv()._isListening     = false
getgenv()._setupLocked     = false

-- Load Rayfield
local ok, Rayfield = pcall(function()
    return loadstring(game:HttpGet("https://sirius.menu/rayfield"))()
end)

if not ok or not Rayfield or type(Rayfield.CreateWindow) ~= "function" then
    warn("[EvomonRoblox Loader] Failed to load Rayfield.")
    return
end

getgenv().__EvomRayfield = Rayfield

local _speedHackEnabled = false
local TweenService      = game:GetService("TweenService")

local function _makeDummy()
    local dummy = {}
    setmetatable(dummy, {
        __index = function(_, key)
            if key == "IsPlaying"     then return false end
            if key == "Length"        then return 0 end
            if key == "Speed"         then return 1 end
            if key == "WeightCurrent" then return 0 end
            if key == "WeightTarget"  then return 0 end
            return _makeDummy()
        end,
        __call     = function() return _makeDummy() end,
        __newindex = function() end,
        __add      = function(a,b) return type(a)=="number" and a or type(b)=="number" and b or 0 end,
        __sub      = function(a,b) return type(a)=="number" and a or type(b)=="number" and b or 0 end,
        __mul      = function(a,b) return type(a)=="number" and a or type(b)=="number" and b or 0 end,
        __div      = function(a,b) return type(a)=="number" and a or type(b)=="number" and b or 0 end,
        __unm      = function() return 0 end,
        __lt       = function() return false end,
        __le       = function() return false end,
        __eq       = function() return false end,
        __len      = function() return 0 end,
        __tostring = function() return "0" end,
    })
    return dummy
end

getgenv().__EvomRunSpeedHack  = function() _speedHackEnabled = true  getgenv().__EvomSpeedActive = true  end
getgenv().__EvomStopSpeedHack = function() _speedHackEnabled = false getgenv().__EvomSpeedActive = false end
getgenv().__EvomSpeedActive   = false


local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ReqEnterNpcBattle = ReplicatedStorage:WaitForChild("Remote"):WaitForChild("Battle"):WaitForChild("ReqEnterNpcBattle")

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args   = table.pack(...)

    -- Boss capture
    if getgenv()._isListening and self == ReqEnterNpcBattle and method == "FireServer" then
        getgenv()._capturedArgs    = args
        getgenv()._isListening     = false
        getgenv()._setupLocked     = false
        getgenv()._bossCaptureDone = true
        return oldNamecall(self, table.unpack(args, 1, args.n))
    end

    if _speedHackEnabled and getgenv().__EvomPremium == true then
        if method == "LoadAnimation" then
            local isCreature = false
            local obj = self
            while obj do
                if obj.Name == "CreatureModelCache" then isCreature = true break end
                local ok2, p = pcall(function() return obj.Parent end)
                if not ok2 then break end
                obj = p
            end
            if isCreature then
                return _makeDummy()
            else
                local track = oldNamecall(self, table.unpack(args, 1, args.n))
                if track and typeof(track) == "Instance" then
                    pcall(function()
                        track:GetPropertyChangedSignal("IsPlaying"):Connect(function()
                            if track.IsPlaying then track:AdjustSpeed(100) end
                        end)
                    end)
                end
                return track
            end
        end

        if method == "Create" and self == TweenService then
            local inst, info, props = args[1], args[2], args[3]
            if info and typeof(info) == "TweenInfo" and inst and typeof(inst) == "Instance" then
                local fast = TweenInfo.new(0.01, info.EasingStyle, info.EasingDirection,
                    info.RepeatCount, info.Reverses, 0)
                return oldNamecall(self, inst, fast, props)
            end
        end
    end

    return oldNamecall(self, table.unpack(args, 1, args.n))
end)

getgenv().__EvomLoaderReady = true

